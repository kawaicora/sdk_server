TZ=Asia/Shanghai

# Flask 基础配置
DEBUG=True #是否开启调试
LISTEN_PORT=80 #监听端口
SERVER_NAME=SDK_SERVER #服务名字
MAX_CONTENT_LENGTH=4294967296 #最大内容大小
TEMPLATES_AUTO_RELOAD=True #是否开启自动模板加载
MAX_COOKIE_SIZE=4093 #最大COOKIES 限制

# 数据库配置
SQLALCHEMY_DATABASE_URI="mysql+pymysql://database_user:database_password@database_address/databese_name"  #mysql数据库配置


SQLALCHEMY_ECHO=False #是否开启数据库操作回显
SQLALCHEMY_TRACK_MODIFICATIONS=False

# SocketIO 配置
SOCKETIO_LOGGER=False #SocketIO日志
ENGINEIO_LOGGER=False

